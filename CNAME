    // ─── LANGUE ───
    function setLang(lang) {
      document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
      document.querySelector(`[onclick="setLang('${lang}')"]`).classList.add('active');
      document.querySelectorAll('.nav-fr').forEach(el => el.style.display = lang === 'fr' ? '' : 'none');
      document.querySelectorAll('.nav-en').forEach(el => el.style.display = lang === 'en' ? '' : 'none');
      localStorage.setItem('hayaLang', lang);
    }

    // Charger la langue sauvegardée
    const savedLang = localStorage.getItem('hayaLang') || 'fr';
    setLang(savedLang);

    // ─── ANIMATIONS SCROLL ───
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          setTimeout(() => entry.target.classList.add('visible'), i * 80);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // ─── NAV SCROLL ───
    window.addEventListener('scroll', () => {
      const nav = document.querySelector('nav');
      if (window.scrollY > 50) {
        nav.style.boxShadow = '0 4px 20px rgba(13,13,43,0.1)';
      } else {
        nav.style.boxShadow = 'none';
      }
    });
  </script>
</body>
</html>
